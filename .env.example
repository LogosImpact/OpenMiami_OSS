# OpenMiami_OSS — environment variables
# Copy to `.env` and fill in. `.env*` is gitignored; only `.env.example` is committed.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Two modes are supported by api/_lib/db.js:
#
#   1. Supabase mode (primary). Set the SUPABASE_* vars below. RLS policies in
#      db/schema.sql act as a defense-in-depth layer. The /resources, /suggest,
#      /categories, /chat routes all use the anon key by default; service role
#      is required for moderator workflows.
#
#   2. Neon / vanilla Postgres mode (alternative; aligns with grantkurz/impact-
#      lab-backend). Set DATABASE_URL only. The shim drops to a `pg.Pool` and
#      RLS is enforced in the API layer (the routes already filter on
#      `verified_at is not null` and `/suggest` is structurally insert-only).
#
# If both are set, Supabase wins. To force Neon mode, leave SUPABASE_URL empty.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used for local docker-compose Postgres+PostGIS and for Neon mode.
DATABASE_URL=postgres://openmiami:openmiami@localhost:5432/openmiami

# ---------------------------------------------------------------------------
# MiaGPT (Claude)
# ---------------------------------------------------------------------------
# Used by scripts and the optional server-side default for /chat. The stub
# front end follows the live demo's BYOK pattern — users paste their own key
# into a session-only input; this env var is the fallback for dev only.
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Front-end (apps/miamiverse)
# ---------------------------------------------------------------------------
VITE_API_BASE=http://localhost:3000
